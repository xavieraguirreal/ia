# Configuración del servidor
PORT=8000

# Conexión a Ollama
OLLAMA_HOST=http://localhost:11434

# Modelos a usar
# Para chat/completions (reemplaza gpt-4o-mini)
CHAT_MODEL=qwen2.5:7b-instruct

# Para embeddings (reemplaza text-embedding-3-small)
EMBEDDING_MODEL=nomic-embed-text

# API Key opcional (dejar vacío para desactivar autenticación)
API_KEY=tu-api-key-secreta

# Debug mode
DEBUG=false
